# 1. Automated Evaluation Harness

This script reads your golden eval sets (`data/eval/sis_eval.jsonl`), sends the questions to your running API, and calculates:
1. **Groundedness / Citation Presence**: Did the model use retrieved sources?
2. **Task Completion**: Did the model refuse when it was supposed to?
3. **Factual Overlap**: A lightweight ROUGE/string-matching score against the reference answer.

## `evaluation/run_eval.py`

```python
# evaluation/run_eval.py
import json
import requests
import time
from pathlib import Path
from rouge_score import rouge_scorer

API_URL = "http://localhost:8000/v1/chat"
EVAL_DIR = Path("data/eval")
REPORT_DIR = Path("evaluation/reports")
REPORT_DIR.mkdir(parents=True, exist_ok=True)

scorer = rouge_scorer.RougeScorer(['rougeL'], use_stemmer=True)

def evaluate_tenant(tenant_id: str):
    file_path = EVAL_DIR / f"{tenant_id}_eval.jsonl"
    if not file_path.exists():
        return
        
    results = []
    total_latency = 0
    citation_success = 0
    refusal_success = 0
    
    with open(file_path, "r", encoding="utf-8") as f:
        for line in f:
            test_case = json.loads(line)
            
            start = time.time()
            # Hit the streaming API, but we just collect the final text
            resp = requests.post(API_URL, json={"tenant_id": tenant_id, "query": test_case["question"]}, stream=True)
            
            full_text = ""
            sources = []
            for chunk in resp.iter_lines():
                if chunk:
                    decoded = chunk.decode('utf-8')
                    if decoded.startswith("data: ") and "[DONE]" not in decoded:
                        data = json.loads(decoded[6:])
                        if "token" in data:
                            full_text += data["token"]
                        if "sources" in data:
                            sources = data["sources"]
            
            latency = time.time() - start
            total_latency += latency
            
            # Metrics
            has_citation = len(sources) > 0
            if has_citation == test_case.get("requires_citation", False):
                citation_success += 1
                
            # Refusal check
            is_refusal = "cannot" in full_text.lower() or "do not have enough" in full_text.lower()
            if is_refusal == test_case.get("requires_refusal", False):
                refusal_success += 1
                
            # ROUGE overlap with reference
            rouge_score = scorer.score(test_case["reference_answer"], full_text)['rougeL'].fmeasure
            
            results.append({
                "question": test_case["question"],
                "generated": full_text,
                "latency": latency,
                "rougeL": rouge_score,
                "pass_citation": has_citation == test_case.get("requires_citation", False),
                "pass_refusal": is_refusal == test_case.get("requires_refusal", False)
            })
            
    # Calculate aggregates
    avg_latency = total_latency / len(results)
    avg_rouge = sum(r["rougeL"] for r in results) / len(results)
    
    report = {
        "tenant_id": tenant_id,
        "total_tests": len(results),
        "avg_latency_sec": round(avg_latency, 2),
        "avg_rougeL": round(avg_rouge, 3),
        "citation_accuracy": f"{citation_success}/{len(results)}",
        "refusal_accuracy": f"{refusal_success}/{len(results)}",
        "details": results
    }
    
    with open(REPORT_DIR / f"{tenant_id}_eval_report.json", "w") as f:
        json.dump(report, f, indent=2)
        
    print(f"[{tenant_id.upper()}] Eval Complete. ROUGE-L: {avg_rouge:.2f} | Citations: {citation_success}/{len(results)}")

if __name__ == "__main__":
    print("Running automated evaluation suite...")
    evaluate_tenant("sis")
    evaluate_tenant("mfg")
```

