# Series 5/6 — Web, Mobile, and Voice Integration

Now we build the application surfaces. The JD specifically requires your models to be integrated into **web, mobile, and voice**.

To fit this into a POC without spending weeks on frontend frameworks, we will build **thin clients** that all talk to your FastAPI backend.

---

# 1. Web UI (Streamlit)

While Next.js is great, **Streamlit** is the industry standard for fast AI Python POCs. It handles streaming, state, and UI in ~100 lines of code.

## `web_app/app.py`

This UI includes:
- A sidebar to switch between tenants (SIS vs Manufacturing)
- A chat window
- Real-time SSE streaming from your FastAPI backend
- Citation rendering

```python
# web_app/app.py
import streamlit as st
import requests
import json

API_URL = "http://localhost:8000/v1/chat"

st.set_page_config(page_title="Multi-Tenant AI Copilot", layout="wide")

st.title("🏢 Multi-Tenant Domain Copilot")

# 1. Tenant Selector
tenant = st.sidebar.selectbox(
    "Select Tenant Context",
    ("sis", "mfg"),
    format_func=lambda x: "🎓 Student Info System (SIS)" if x == "sis" else "⚙️ Manufacturing (MFG)"
)

# Reset chat if tenant changes
if "current_tenant" not in st.session_state or st.session_state.current_tenant != tenant:
    st.session_state.current_tenant = tenant
    st.session_state.messages = []

# Display chat history
for msg in st.session_state.messages:
    with st.chat_message(msg["role"]):
        st.markdown(msg["content"])
        if "sources" in msg and msg["sources"]:
            st.caption(f"📚 Sources: {', '.join(msg['sources'])}")

# Chat input
if prompt := st.chat_input(f"Ask the {tenant.upper()} assistant..."):
    # Append user message
    st.session_state.messages.append({"role": "user", "content": prompt})
    with st.chat_message("user"):
        st.markdown(prompt)

    # Streaming response
    with st.chat_message("assistant"):
        message_placeholder = st.empty()
        full_response = ""
        sources = []

        try:
            # Call FastAPI streaming endpoint
            with requests.post(
                API_URL, 
                json={"tenant_id": tenant, "query": prompt}, 
                stream=True
            ) as r:
                for line in r.iter_lines():
                    if line:
                        decoded_line = line.decode('utf-8')
                        if decoded_line.startswith("data: "):
                            data_str = decoded_line[6:]
                            if data_str == "[DONE]":
                                break
                            
                            data = json.loads(data_str)
                            if "token" in data:
                                full_response += data["token"]
                                message_placeholder.markdown(full_response + "▌")
                            elif "sources" in data:
                                sources = data["sources"]

            message_placeholder.markdown(full_response)
            if sources:
                st.caption(f"📚 Sources: {', '.join(sources)}")
            
            # Save assistant message
            st.session_state.messages.append({
                "role": "assistant", 
                "content": full_response,
                "sources": sources
            })

        except Exception as e:
            st.error(f"Backend connection failed: {e}")
```

### Run it:
```bash
pip install streamlit requests
streamlit run web_app/app.py
```

