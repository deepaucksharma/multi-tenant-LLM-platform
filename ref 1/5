# 3. Voice Agent (Python Local Script)

The JD emphasizes voice STT -> LLM -> TTS. 

To run this on your desktop without burning GPU memory or paying API fees, use:
- **STT**: `faster-whisper` (runs perfectly on CPU `tiny.en` model)
- **TTS**: `pyttsx3` (local offline text-to-speech)
- **Mic input**: `speech_recognition`

## Setup
```bash
pip install faster-whisper SpeechRecognition pyttsx3 pyaudio requests
```
*(Note: If PyAudio fails to install on Windows, install it via `pip install pipwin && pipwin install pyaudio` or use WSL).*

## `voice/voice_agent.py`

```python
# voice/voice_agent.py
import speech_recognition as sr
import pyttsx3
import requests
import json
from faster_whisper import WhisperModel

API_URL = "http://localhost:8000/v1/chat"
TENANT = "sis" # Hardcode or prompt user to select

print("Loading Whisper STT model on CPU (to save VRAM)...")
whisper_model = WhisperModel("tiny.en", device="cpu", compute_type="int8")

print("Initializing TTS engine...")
tts_engine = pyttsx3.init()
tts_engine.setProperty('rate', 160)

def speak(text):
    print(f"\n[Agent Speaks]: {text}")
    tts_engine.say(text)
    tts_engine.runAndWait()

def chat_with_llm(query):
    print(f"\n[Thinking...]")
    full_response = ""
    try:
        # Request stream from our FastAPI backend
        with requests.post(API_URL, json={"tenant_id": TENANT, "query": query}, stream=True) as r:
            for line in r.iter_lines():
                if line:
                    decoded = line.decode('utf-8')
                    if decoded.startswith("data: ") and not decoded.includes("[DONE]"):
                        data = json.loads(decoded[6:])
                        if "token" in data:
                            full_response += data["token"]
                            print(data["token"], end="", flush=True)
    except Exception as e:
        full_response = "I'm having trouble connecting to the brain."
    return full_response

def main():
    recognizer = sr.Recognizer()
    
    print(f"\n=== Voice Agent Active ({TENANT.upper()} Mode) ===")
    print("Press Ctrl+C to exit.\n")
    
    speak("Hello. I am your voice assistant. How can I help you today?")
    
    while True:
        with sr.Microphone() as source:
            print("\n[Listening... Speak now]")
            recognizer.adjust_for_ambient_noise(source, duration=0.5)
            audio = recognizer.listen(source)
            
            with open("temp.wav", "wb") as f:
                f.write(audio.get_wav_data())
                
        print("[Transcribing...]")
        segments, info = whisper_model.transcribe("temp.wav", beam_size=1)
        transcription = " ".join([segment.text for segment in segments]).strip()
        
        if not transcription:
            continue
            
        print(f"\n[You]: {transcription}")
        
        # Guard word to exit
        if "goodbye" in transcription.lower() or "exit" in transcription.lower():
            speak("Goodbye!")
            break
            
        # Get LLM response and speak it
        response_text = chat_with_llm(transcription)
        
        # Clean up response for TTS (remove citations/markdown)
        clean_text = response_text.split("[Source")[0].replace("*", "").strip()
        speak(clean_text)

if __name__ == "__main__":
    main()
```

### Run it:
Ensure the FastAPI backend is running on port 8000, then:
```bash
python voice/voice_agent.py
```
Talk into your mic! It will capture audio, transcribe via Whisper, hit your multi-tenant backend, stream the text to the terminal, and speak the result out loud.

