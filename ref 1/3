# 5. Small helper to prepare chat training data

```python
# training/prepare_chat_data.py
import json
from pathlib import Path

SYSTEM_PROMPTS = {
    "sis": "You are a student information system assistant. Answer using tenant-specific school policy context. Do not reveal private student information without authorization.",
    "mfg": "You are a manufacturing operations assistant. Answer using SOP, quality, CAPA, maintenance, and safety context. Never recommend bypassing required safety procedures."
}

def convert(in_path: Path, out_path: Path, tenant_id: str):
    rows = []
    with open(in_path, "r", encoding="utf-8") as f:
        for line in f:
            x = json.loads(line)
            rows.append({
                "messages": [
                    {"role": "system", "content": SYSTEM_PROMPTS[tenant_id]},
                    {"role": "user", "content": x["instruction"]},
                    {"role": "assistant", "content": x["output"]}
                ]
            })

    out_path.parent.mkdir(parents=True, exist_ok=True)
    with open(out_path, "w", encoding="utf-8") as f:
        for row in rows:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")

if __name__ == "__main__":
    convert(Path("data/sft/sis_train.jsonl"), Path("data/sft/sis_chat.jsonl"), "sis")
    convert(Path("data/sft/mfg_train.jsonl"), Path("data/sft/mfg_chat.jsonl"), "mfg")
    print("Chat-format datasets written.")
```

Run this once before training.

