# 4. Audit Logging & Compliance

For the POC, write an audit log to a local SQLite database.

## `inference/audit.py`

```python
# inference/audit.py
import sqlite3
import time

DB_PATH = "logs/audit.db"

def init_db():
    import os
    os.makedirs("logs", exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute('''
        CREATE TABLE IF NOT EXISTS requests (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp REAL,
            tenant_id TEXT,
            adapter_version TEXT,
            query TEXT,
            sources TEXT,
            latency REAL
        )
    ''')
    conn.commit()
    conn.close()

def log_request(tenant_id, adapter_version, query, sources, latency):
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.execute(
        "INSERT INTO requests (timestamp, tenant_id, adapter_version, query, sources, latency) VALUES (?, ?, ?, ?, ?, ?)",
        (time.time(), tenant_id, adapter_version, query, str(sources), latency)
    )
    conn.commit()
    conn.close()

init_db()
```

