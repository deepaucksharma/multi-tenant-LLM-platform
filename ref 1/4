# 6. FastAPI Server with SSE Streaming

This brings it all together.

## `inference/main.py`

```python
# inference/main.py
import time
import json
from fastapi import FastAPI, BackgroundTasks
from fastapi.responses import StreamingResponse
from pydantic import BaseModel
from threading import Thread
from transformers import TextIteratorStreamer

from inference.model_manager import model_manager
from inference.retriever import get_context, build_prompt
from inference.audit import log_request
from inference.router import resolve_adapter

app = FastAPI(title="Multi-Tenant LLM API")

class ChatRequest(BaseModel):
    tenant_id: str
    query: str

@app.post("/v1/chat")
async def chat_endpoint(req: ChatRequest, background_tasks: BackgroundTasks):
    start_time = time.time()
    
    # 1. Canary Router: determine which adapter version to use
    adapter_name = resolve_adapter(req.tenant_id)
    
    # 2. Swap to the correct tenant adapter in memory instantly
    model_manager.set_tenant(adapter_name)
    
    # 3. Retrieve context
    context, sources = get_context(req.tenant_id, req.query)
    
    # 4. Build prompt
    messages = build_prompt(req.tenant_id, req.query, context)
    text_input = model_manager.tokenizer.apply_chat_template(
        messages, tokenize=False, add_generation_prompt=True
    )
    
    inputs = model_manager.tokenizer(text_input, return_tensors="pt").to("cuda")

    # 5. Setup Streamer
    streamer = TextIteratorStreamer(
        model_manager.tokenizer, 
        skip_prompt=True, 
        skip_special_tokens=True
    )
    
    generation_kwargs = dict(
        **inputs,
        max_new_tokens=256,
        do_sample=False,
        temperature=0.0,
        streamer=streamer
    )

    # 6. Run generation in background thread
    thread = Thread(target=model_manager.model.generate, kwargs=generation_kwargs)
    thread.start()

    async def event_generator():
        full_response = ""
        # Yield tokens as they arrive
        for text in streamer:
            full_response += text
            yield f"data: {json.dumps({'token': text})}\n\n"
        
        # Yield sources at the end
        yield f"data: {json.dumps({'sources': sources})}\n\n"
        yield "data: [DONE]\n\n"
        
        # Log to audit DB
        latency = time.time() - start_time
        log_request(req.tenant_id, adapter_name, req.query, sources, latency)

    return StreamingResponse(event_generator(), media_type="text/event-stream")
```

