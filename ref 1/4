# 1. Tenant-Isolated RAG Strategy

To guarantee zero cross-tenant leakage, the safest and most explicit method is to use **separate Chroma collections** for each tenant.

## `rag/build_index.py`

This script reads your chunks and builds the vector index.

```python
# rag/build_index.py
import json
import chromadb
from pathlib import Path
from sentence_transformers import SentenceTransformer

CHROMA_DIR = Path("data/chroma")
CHROMA_DIR.mkdir(parents=True, exist_ok=True)

def main():
    # Initialize local persistent Chroma
    client = chromadb.PersistentClient(path=str(CHROMA_DIR))
    
    # Load lightweight embedding model
    print("Loading embedding model...")
    embedder = SentenceTransformer("all-MiniLM-L6-v2")

    for tenant_id in ["sis", "mfg"]:
        chunk_file = Path(f"data/chunks/{tenant_id}_chunks.jsonl")
        if not chunk_file.exists():
            continue

        print(f"Processing {tenant_id}...")
        
        # Create or reset collection
        try:
            client.delete_collection(name=f"{tenant_id}_docs")
        except:
            pass
        collection = client.create_collection(name=f"{tenant_id}_docs")

        docs, metadatas, ids, embeddings = [], [], [], []

        with open(chunk_file, "r", encoding="utf-8") as f:
            for line in f:
                chunk = json.loads(line)
                docs.append(chunk["text"])
                metadatas.append({"title": chunk["title"], "source": chunk["source"]})
                ids.append(chunk["chunk_id"])

        # Create embeddings in batches
        batch_size = 64
        for i in range(0, len(docs), batch_size):
            batch_docs = docs[i:i+batch_size]
            batch_embs = embedder.encode(batch_docs).tolist()
            
            collection.add(
                documents=batch_docs,
                embeddings=batch_embs,
                metadatas=metadatas[i:i+batch_size],
                ids=ids[i:i+batch_size]
            )
            print(f"  Indexed {min(i+batch_size, len(docs))}/{len(docs)} chunks")

    print("Indexing complete.")

if __name__ == "__main__":
    main()
```

Run this once: `python rag/build_index.py`.

