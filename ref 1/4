# 3. RAG Retrieval & Prompt Construction

## `inference/retriever.py`

```python
# inference/retriever.py
import chromadb
from sentence_transformers import SentenceTransformer

client = chromadb.PersistentClient(path="data/chroma")
embedder = SentenceTransformer("all-MiniLM-L6-v2")

SYSTEM_PROMPTS = {
    "sis": "You are a Student Information System assistant. Answer using ONLY the provided context. If the answer is not in the context, say 'I do not have enough verified context.' Cite sources. Do not reveal unauthorized student data.",
    "mfg": "You are a Manufacturing Operations assistant. Answer using ONLY the provided context. Never suggest bypassing safety rules. Cite sources. If unclear, recommend escalating to a supervisor."
}

def get_context(tenant_id: str, query: str, top_k: int = 3):
    try:
        collection = client.get_collection(name=f"{tenant_id}_docs")
    except:
        return "", []

    query_emb = embedder.encode([query]).tolist()
    results = collection.query(query_embeddings=query_emb, n_results=top_k)
    
    if not results["documents"][0]:
        return "", []

    context_texts = []
    sources = set()
    
    for doc, meta in zip(results["documents"][0], results["metadatas"][0]):
        context_texts.append(f"Excerpt from {meta['title']}:\n{doc}")
        sources.add(meta['title'])
        
    return "\n\n".join(context_texts), list(sources)

def build_prompt(tenant_id: str, query: str, context: str):
    sys_prompt = SYSTEM_PROMPTS.get(tenant_id, "You are a helpful assistant.")
    
    if context:
        user_msg = f"Context:\n{context}\n\nQuestion: {query}"
    else:
        user_msg = query

    return [
        {"role": "system", "content": sys_prompt},
        {"role": "user", "content": user_msg}
    ]
```

