# 19. `pipeline/quality_report.py`

This is your governance/compliance proof.

It should report:
- number of docs
- number of chunks
- duplicate rate
- PII hit count
- topic coverage
- training readiness

## Minimal version

```python
# pipeline/quality_report.py
import json
from pathlib import Path
from collections import Counter

PROC_DIR = Path("data/processed")
CHUNK_DIR = Path("data/chunks")
REPORT_DIR = Path("data/reports")
REPORT_DIR.mkdir(parents=True, exist_ok=True)

def load_jsonl(path):
    rows = []
    if not path.exists():
        return rows
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            rows.append(json.loads(line))
    return rows

def build_report(tenant_id):
    docs = load_jsonl(PROC_DIR / tenant_id / "documents.jsonl")
    chunks = load_jsonl(CHUNK_DIR / f"{tenant_id}_chunks.jsonl")

    topic_counts = Counter(d["topic"] for d in docs)
    pii_hits = sum(d.get("pii_count", 0) for d in docs)
    duplicate_rate = 0.0
    if docs:
        unique_hashes = len(set(d["sha1"] for d in docs))
        duplicate_rate = 1 - (unique_hashes / len(docs))

    approved = (
        len(docs) >= 10 and
        len(chunks) >= 30 and
        pii_hits == 0
    )

    report = f"""# Data Quality Report: {tenant_id}

## Summary
- Documents: {len(docs)}
- Chunks: {len(chunks)}
- Duplicate rate: {duplicate_rate:.2%}
- PII hits: {pii_hits}
- Training approved: {"YES" if approved else "NO"}

## Topic coverage
"""
    for topic, count in topic_counts.items():
        report += f"- {topic}: {count}\n"

    if not approved:
        report += "\n## Action items\n"
        if len(docs) < 10:
            report += "- Add more source documents\n"
        if len(chunks) < 30:
            report += "- Increase usable chunk coverage\n"
        if pii_hits > 0:
            report += "- Review and redact remaining PII\n"

    out_path = REPORT_DIR / f"{tenant_id}_quality_report.md"
    out_path.write_text(report, encoding="utf-8")
    print(f"Wrote {out_path}")

def main():
    for tenant_id in ["sis", "mfg"]:
        build_report(tenant_id)

if __name__ == "__main__":
    main()
```

