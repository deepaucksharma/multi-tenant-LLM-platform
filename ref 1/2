# 9. `pipeline/chunk_docs.py`

You need chunks for RAG and for QA generation.

## Chunking strategy
For your use case:
- chunk size: **400–600 words** or ~**500–700 tokens**
- overlap: **60–100 words**
- preserve metadata

For a quick POC, chunk by paragraphs rather than raw character slicing.

## Minimal version

```python
# pipeline/chunk_docs.py
import json
from pathlib import Path

PROC_DIR = Path("data/processed")
CHUNK_DIR = Path("data/chunks")
CHUNK_DIR.mkdir(parents=True, exist_ok=True)

MAX_CHARS = 1800
OVERLAP_CHARS = 250

def chunk_text(text: str, max_chars=MAX_CHARS, overlap=OVERLAP_CHARS):
    text = text.strip()
    chunks = []
    start = 0
    while start < len(text):
        end = min(len(text), start + max_chars)
        chunk = text[start:end]
        chunks.append((chunk, start, end))
        if end == len(text):
            break
        start = end - overlap
    return chunks

def main():
    for tenant_dir in PROC_DIR.iterdir():
        in_file = tenant_dir / "documents.jsonl"
        if not in_file.exists():
            continue

        out_file = CHUNK_DIR / f"{tenant_dir.name}_chunks.jsonl"
        out_records = []

        with open(in_file, "r", encoding="utf-8") as f:
            for line in f:
                doc = json.loads(line)
                for i, (chunk, start, end) in enumerate(chunk_text(doc["content"])):
                    if len(chunk.strip()) < 120:
                        continue
                    out_records.append({
                        "tenant_id": doc["tenant_id"],
                        "doc_id": doc["doc_id"],
                        "chunk_id": f"{doc['doc_id']}_{i:03d}",
                        "title": doc["title"],
                        "topic": doc["topic"],
                        "doc_type": doc["doc_type"],
                        "source": doc["source"],
                        "sensitivity": doc["sensitivity"],
                        "text": chunk.strip(),
                        "start_char": start,
                        "end_char": end
                    })

        with open(out_file, "w", encoding="utf-8") as f:
            for r in out_records:
                f.write(json.dumps(r, ensure_ascii=False) + "\n")

        print(f"{tenant_dir.name}: wrote {len(out_records)} chunks")

if __name__ == "__main__":
    main()
```

