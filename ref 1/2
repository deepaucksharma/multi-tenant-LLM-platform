# 8. `pipeline/clean_redact.py`

This script handles:

- whitespace cleanup
- duplicate removal
- light PII detection
- optional redaction

For the POC, **regex-based PII checks are enough**.

## What to detect
- emails
- phone numbers
- SSN-like patterns
- student IDs / employee IDs if patterned

## Minimal version

```python
# pipeline/clean_redact.py
import json
import re
from pathlib import Path

PROC_DIR = Path("data/processed")

EMAIL_RE = re.compile(r"\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}\b")
PHONE_RE = re.compile(r"\b(?:\+?1[-.\s]?)?\(?\d{3}\)?[-.\s]?\d{3}[-.\s]?\d{4}\b")
SSN_RE = re.compile(r"\b\d{3}-\d{2}-\d{4}\b")
ID_RE = re.compile(r"\b(?:SID|EMP|STU)[-_]?\d{4,10}\b")

def normalize(text: str) -> str:
    text = text.replace("\r", "\n")
    text = re.sub(r"\n{3,}", "\n\n", text)
    text = re.sub(r"[ \t]+", " ", text)
    return text.strip()

def find_pii(text: str):
    hits = []
    for name, regex in [
        ("email", EMAIL_RE),
        ("phone", PHONE_RE),
        ("ssn", SSN_RE),
        ("id", ID_RE),
    ]:
        matches = regex.findall(text)
        for m in matches:
            hits.append({"type": name, "value": m})
    return hits

def redact(text: str) -> str:
    text = EMAIL_RE.sub("[REDACTED_EMAIL]", text)
    text = PHONE_RE.sub("[REDACTED_PHONE]", text)
    text = SSN_RE.sub("[REDACTED_SSN]", text)
    text = ID_RE.sub("[REDACTED_ID]", text)
    return text

def process_file(path: Path):
    records = []
    seen_hashes = set()

    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            obj = json.loads(line)
            content = normalize(obj["content"])
            pii_hits = find_pii(content)

            if obj["sha1"] in seen_hashes:
                continue
            seen_hashes.add(obj["sha1"])

            obj["content"] = redact(content)
            obj["pii_hits"] = pii_hits
            obj["pii_count"] = len(pii_hits)
            records.append(obj)

    with open(path, "w", encoding="utf-8") as f:
        for r in records:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")

    return len(records)

def main():
    for tenant_dir in PROC_DIR.iterdir():
        file_path = tenant_dir / "documents.jsonl"
        if file_path.exists():
            count = process_file(file_path)
            print(f"cleaned {tenant_dir.name}: {count} docs")

if __name__ == "__main__":
    main()
```

