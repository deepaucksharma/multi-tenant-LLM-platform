# 12. `pipeline/build_sft.py`

The easiest approach:
- generate QA from document titles/topics
- create template questions
- use exact source-grounded answers from document snippets
- hand-curate the top 80–100

## Minimal version

```python
# pipeline/build_sft.py
import json
from pathlib import Path
from collections import defaultdict

CHUNK_DIR = Path("data/chunks")
OUT_DIR = Path("data/sft")
OUT_DIR.mkdir(parents=True, exist_ok=True)

QUESTION_TEMPLATES = {
    "sis": {
        "enrollment": [
            "What is the enrollment process?",
            "How are transfer students enrolled?",
            "What documents are required for enrollment?"
        ],
        "attendance": [
            "How is attendance recorded?",
            "What happens after repeated unexcused absences?",
            "How are excused absences handled?"
        ],
        "transcripts": [
            "How are official transcripts requested?",
            "How long does transcript processing take?",
            "When can transcripts be held?"
        ],
        "ferpa_compliance": [
            "What student information is protected?",
            "When can records be disclosed without consent?",
            "What are parent FERPA rights?"
        ]
    },
    "mfg": {
        "standard_operating_procedures": [
            "What is the assembly line startup procedure?",
            "What should be checked before startup?",
            "What should happen if startup checks fail?"
        ],
        "capa": [
            "What triggers a CAPA?",
            "What are the steps in the CAPA process?",
            "How is CAPA effectiveness verified?"
        ],
        "safety_protocols": [
            "What PPE is required?",
            "What is the emergency fire procedure?",
            "How quickly must incidents be reported?"
        ],
        "quality_control": [
            "How is incoming material inspected?",
            "What happens to non-conforming material?",
            "How is traceability maintained?"
        ]
    }
}

def load_chunks(path):
    rows = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            rows.append(json.loads(line))
    return rows

def build_examples(tenant_id, rows):
    by_topic = defaultdict(list)
    for r in rows:
        by_topic[r["topic"]].append(r)

    examples = []
    for topic, qs in QUESTION_TEMPLATES.get(tenant_id, {}).items():
        topic_chunks = by_topic.get(topic, [])
        if not topic_chunks:
            continue
        # take first 1-2 chunks as source material
        source_text = " ".join(c["text"] for c in topic_chunks[:2])[:900]
        source_title = topic_chunks[0]["title"]

        for q in qs:
            examples.append({
                "tenant_id": tenant_id,
                "instruction": q,
                "input": "",
                "output": f"{source_text} [Source: {source_title}]"
            })
    return examples

def main():
    for tenant_id in ["sis", "mfg"]:
        rows = load_chunks(CHUNK_DIR / f"{tenant_id}_chunks.jsonl")
        data = build_examples(tenant_id, rows)

        out_file = OUT_DIR / f"{tenant_id}_train.jsonl"
        with open(out_file, "w", encoding="utf-8") as f:
            for x in data:
                f.write(json.dumps(x, ensure_ascii=False) + "\n")

        print(f"{tenant_id}: wrote {len(data)} SFT examples")

if __name__ == "__main__":
    main()
```

## Important
This script gives you a starting set.  
Then manually improve examples until each tenant has **80–100 good examples**.

That manual cleanup matters.

