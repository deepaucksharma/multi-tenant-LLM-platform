# 7. `pipeline/ingest.py`

This script reads JSON/TXT/PDF/DOCX and normalizes everything into one processed JSONL per tenant.

## What it should do
- scan `data/raw/{tenant}`
- load each file
- assign `tenant_id`
- create `doc_id`
- hash content
- write `data/processed/{tenant}/documents.jsonl`

## Minimal version

```python
# pipeline/ingest.py
import json
import hashlib
from pathlib import Path
from pypdf import PdfReader
from docx import Document

RAW_DIR = Path("data/raw")
OUT_DIR = Path("data/processed")

def sha1_text(text: str) -> str:
    return hashlib.sha1(text.encode("utf-8")).hexdigest()

def load_text_file(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="ignore")

def load_pdf(path: Path) -> str:
    reader = PdfReader(str(path))
    return "\n".join(page.extract_text() or "" for page in reader.pages)

def load_docx(path: Path) -> str:
    doc = Document(str(path))
    return "\n".join(p.text for p in doc.paragraphs)

def load_any(path: Path):
    if path.suffix == ".json":
        obj = json.loads(path.read_text(encoding="utf-8"))
        return obj
    elif path.suffix == ".txt":
        return {"title": path.stem, "content": load_text_file(path)}
    elif path.suffix == ".pdf":
        return {"title": path.stem, "content": load_pdf(path), "doc_type": "pdf"}
    elif path.suffix == ".docx":
        return {"title": path.stem, "content": load_docx(path), "doc_type": "docx"}
    return None

def main():
    for tenant_dir in RAW_DIR.iterdir():
        if not tenant_dir.is_dir():
            continue
        tenant_id = tenant_dir.name
        out_path = OUT_DIR / tenant_id
        out_path.mkdir(parents=True, exist_ok=True)
        records = []

        for path in tenant_dir.iterdir():
            obj = load_any(path)
            if not obj:
                continue
            content = obj.get("content", "").strip()
            if not content:
                continue

            title = obj.get("title", path.stem)
            topic = obj.get("topic", "general")
            doc_type = obj.get("doc_type", path.suffix.replace(".", "") or "text")
            source = obj.get("source", "local")
            sensitivity = obj.get("sensitivity", "internal")
            doc_id = f"{tenant_id}_{path.stem}"

            records.append({
                "tenant_id": tenant_id,
                "doc_id": doc_id,
                "title": title,
                "topic": topic,
                "doc_type": doc_type,
                "source": source,
                "sensitivity": sensitivity,
                "content": content,
                "sha1": sha1_text(content)
            })

        with open(out_path / "documents.jsonl", "w", encoding="utf-8") as f:
            for r in records:
                f.write(json.dumps(r, ensure_ascii=False) + "\n")

        print(f"{tenant_id}: wrote {len(records)} documents")

if __name__ == "__main__":
    main()
```

