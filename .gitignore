# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Env
.env
*.env.local

# Data (generated)
data/chroma/
data/raw/
data/sis/
data/mfg/

# Models — binary weights & base downloads are too large for GitHub.
# Push with: python -m training.push_to_hub --all --weights
# Only metadata/config JSONs are tracked in git.
models/**/*.safetensors
models/**/*.bin
models/**/*.pt
models/**/*.gguf
models/**/*.ggml
models/**/checkpoint-*/
models/base/
models/merged/
models/registry.json
# Allow adapter metadata so training results are recorded
!models/adapters/**/adapter_config.json
!models/adapters/**/training_metadata.json
!models/adapters/**/tokenizer_config.json
!models/adapters/**/tokenizer.json
!models/adapters/**/special_tokens_map.json
!models/adapters/**/generation_config.json

# MLflow
mlruns/
mlflow.db

# Logs
logs/
*.log

# Node / Next.js
node_modules/
.next/
out/
.npm

# Flutter
mobile_app/.dart_tool/
mobile_app/build/
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies

# Evaluation reports — keep JSON results, exclude bulky HTML renders
# evaluation/reports/*.json are small and valuable as a historical record
evaluation/reports/*.html

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
