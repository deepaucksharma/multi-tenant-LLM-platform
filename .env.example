BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEVICE=auto
USE_4BIT=auto
MAX_SEQ_LEN=512
DATA_ROOT=./data
CHROMA_PERSIST_DIR=./data/chroma
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
SQLITE_DB=./logs/audit.db
API_PORT=8000
WEB_PORT=3000
VOICE_PORT=8001
# -----------------------------------------------------------------------
# DEMO_MODE — when true, unauthenticated requests are accepted.
# SECURITY: Do NOT enable this in any shared or internet-facing environment.
# Requires DEMO_TENANT to be set; otherwise unauthenticated requests return
# HTTP 401 even when DEMO_MODE=true.
# -----------------------------------------------------------------------
DEMO_MODE=false
# DEMO_TENANT: pin unauthenticated requests to a single tenant (e.g. "sis" or "mfg").
# Required when DEMO_MODE=true. Leave empty to disable demo access entirely.
DEMO_TENANT=
HF_TOKEN=
# Hugging Face Hub — adapter + dataset publishing
# Profile: https://huggingface.co/deepaucksharma
# Push adapters:  make push-hub          (metadata only)
#                 make push-hub-weights  (includes .safetensors)
#                 make push-hub-merged   (full merged models ~3 GB)
#                 make push-hub-private  (create private repos)
# Push datasets:  make push-datasets     (SFT/DPO JSONL files)
# Get a write-scoped token from https://huggingface.co/settings/tokens
HF_HUB_NAMESPACE=deepaucksharma
HF_REPO_PREFIX=multi-tenant-llm
# Dataset repos use HF_DATASET_PREFIX (falls back to HF_REPO_PREFIX if unset)
HF_DATASET_PREFIX=multi-tenant-llm
# Set true to create all new Hub repos as private (default: false = public for POC)
HF_REPO_PRIVATE=false

# ── Inference backend ──────────────────────────────────────────────────────────
# auto        → tries Ollama, then HF Inference API (if HF_TOKEN set), then local HF
# ollama      → local Ollama HTTP server
# hf          → local Hugging Face transformers (loads model locally)
# hf_inference → HF Serverless Inference API (no local GPU needed; rate-limited on free tier)
INFERENCE_BACKEND=auto

# HF Serverless Inference API model overrides (used when INFERENCE_BACKEND=hf_inference)
# Fallback chain: HF_INFERENCE_MODEL_{TENANT}_{TYPE} → HF_INFERENCE_MODEL_{TENANT} → HF_INFERENCE_MODEL → default
HF_INFERENCE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# HF_INFERENCE_MODEL_SIS=deepaucksharma/multi-tenant-llm-sis-sft
# HF_INFERENCE_MODEL_MFG=deepaucksharma/multi-tenant-llm-mfg-sft
# HF_INFERENCE_MODEL_SIS_SFT=deepaucksharma/multi-tenant-llm-sis-sft
# HF_INFERENCE_MODEL_SIS_DPO=deepaucksharma/multi-tenant-llm-sis-dpo
# Timeout for HF Inference API requests (seconds)
HF_INFERENCE_TIMEOUT_SEC=60
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_DEFAULT=qwen2.5:1.5b
OLLAMA_MODEL_SIS=qwen2.5:1.5b
OLLAMA_MODEL_MFG=qwen2.5:1.5b
OLLAMA_SOURCE_MODEL=qwen2.5:1.5b
# Model used for local smoke-test runs (make train-smoke-tiny).
# CI uses hf-internal-testing/tiny-random-LlamaForCausalLM (set in pipeline.yml env).
SMOKE_TEST_BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# SMOKE_TEST_LOCAL_MODEL_PATH=./models/base/tinyllama
# Optional per-tenant/per-variant overrides:
# OLLAMA_MODEL_SIS_SFT=tenant-sis-sft
# OLLAMA_MODEL_MFG_SFT=tenant-mfg-sft
# OLLAMA_MODEL_SIS_DPO=tenant-sis-dpo
# OLLAMA_SOURCE_MODEL_SFT=qwen2.5:1.5b
