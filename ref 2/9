              if isinstance(suite_data, dict):
                  if 'error' in suite_data:
                      continue
                  for tid, data in suite_data.items():
                      if isinstance(data, dict) and 'pass_rate' in data:
                          if data['pass_rate'] < 0.5:
                              failed_suites.append(f'{suite_name}/{tid}: {data[\"pass_rate\"]:.0%}')

          if failed_suites:
              print('❌ Evaluation gates FAILED:')
              for f in failed_suites:
                  print(f'  - {f}')
              sys.exit(1)
          else:
              print('✅ All evaluation gates passed')
          "

      - name: Upload evaluation reports
        uses: actions/upload-artifact@v4
        with:
          name: evaluation-reports
          path: evaluation/reports/
          retention-days: 30

  # ============================================================
  # Job 4: Build and Test API
  # ============================================================
  api-test:
    name: API Build & Test
    runs-on: ubuntu-latest
    needs: lint-and-test
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Test API schema imports
        run: |
          python -c "
          from inference.schemas import ChatRequest, ChatResponse, FeedbackRequest
          from inference.tenant_router import list_tenants, TENANT_ROUTES
          from inference.canary import CanaryManager
          from inference.audit_logger import AuditLogger

          print(f'Tenants configured: {list(TENANT_ROUTES.keys())}')
          print(f'ChatRequest fields: {list(ChatRequest.model_fields.keys())}')

          # Test audit logger
          al = AuditLogger(db_path='/tmp/test_audit.db')
          req_id = al.log_request(tenant_id='sis', user_message='test', model_response='test response')
          fb_id = al.log_feedback(request_id=req_id, tenant_id='sis', rating=5)
          stats = al.get_request_stats('sis', hours=1)
          print(f'Audit test: request={req_id}, feedback={fb_id}, stats={stats}')
          print('API schema tests passed ✅')
          "

      - name: Test monitoring imports
        run: |
          python -c "
          from monitoring.metrics_collector import MetricsCollector
          from monitoring.alerting import AlertManager, ALERT_RULES
          from mlops.retrain_trigger import check_retrain_needed
          from mlops.rollback import list_versions

          mc = MetricsCollector(audit_db_path='/tmp/nonexistent.db')
          system = mc.collect_system_metrics()
          print(f'System metrics: CPU={system.cpu_percent}%, MEM={system.memory_percent}%')
          print(f'Alert rules defined: {len(ALERT_RULES)}')
          print('Monitoring tests passed ✅')
          "

  # ============================================================
  # Job 5: Web App Build
  # ============================================================
  web-build:
    name: Web App Build
    runs-on: ubuntu-latest
    needs: lint-and-test
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: web_app/package.json

      - name: Install dependencies
        working-directory: web_app
        run: npm ci

      - name: Type check
        working-directory: web_app
        run: npx tsc --noEmit || true

      - name: Build
        working-directory: web_app
        run: npm run build

  # ============================================================
  # Job 6: Summary
  # ============================================================
  ci-summary:
    name: CI Summary
    runs-on: ubuntu-latest
    needs: [lint-and-test, data-pipeline, evaluation, api-test, web-build]
    if: always()
    steps:
      - name: Summary
        run: |
          echo "## CI/CD Pipeline Results" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Job | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|-----|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| Lint & Test | ${{ needs.lint-and-test.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Data Pipeline | ${{ needs.data-pipeline.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Evaluation | ${{ needs.evaluation.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| API Test | ${{ needs.api-test.result }} |" >> $GITHUB_STEP_SUMMARY
          echo "| Web Build | ${{ needs.web-build.result }} |" >> $GITHUB_STEP_SUMMARY
