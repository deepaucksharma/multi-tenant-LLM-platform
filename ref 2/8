      method: 'POST',
      body: formData,
    });

    const result = await response.json();

    if (result.status === 'success') {
      // Show transcript
      addTurn('user', result.user_text, null);

      statusEl.textContent = 'Generating response...';

      addTurn('assistant', result.assistant_text, result.timing);

      // Play audio
