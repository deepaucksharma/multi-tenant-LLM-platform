def augment_examples(examples: List[Dict], multiplier: int = 2) -> List[Dict]:
    """
    Create variations of existing examples by:
    - Rephrasing instructions
    - Adding context variations
    """
    prefixes = [
        "Can you explain ",
        "Please describe ",
        "What is the procedure for ",
        "Tell me about ",
        "I need to know about ",
        "Explain the process of ",
        "How does the system handle ",
        "What are the requirements for ",
        "Could you clarify ",
        "Walk me through ",
    ]

    augmented = list(examples)  # Start with originals

    for _ in range(multiplier - 1):
        for ex in examples:
            original_q = ex["instruction"]
            # Simple rephrasing: add a prefix
            prefix = random.choice(prefixes)
            # Remove question mark and common starters for cleaner merge
            clean_q = original_q.lower()
            for starter in ["what is ", "what are ", "how ", "when ", "can ", "what "]:
                if clean_q.startswith(starter):
                    clean_q = clean_q[len(starter):]
                    break
            new_q = f"{prefix}{clean_q}"
            if not new_q.endswith("?"):
                new_q += "?"

            augmented.append({
                "instruction": new_q,
                "input": ex.get("input", ""),
                "output": ex["output"],
                "topic": ex["topic"],
            })

    return augmented


def build_sft_dataset(tenant_id: str) -> List[Dict]:
    """Build SFT dataset for a tenant."""
    config = TENANTS[tenant_id]
    config.sft_dir.mkdir(parents=True, exist_ok=True)

    # Get base examples
    if tenant_id == "sis":
        examples = SIS_SFT_EXAMPLES
    elif tenant_id == "mfg":
        examples = MFG_SFT_EXAMPLES
    else:
        logger.error(f"Unknown tenant: {tenant_id}")
        return []

    # Augment to reach target count
    target_count = 120
    current_count = len(examples)
    multiplier = max(2, (target_count // current_count) + 1)
    augmented = augment_examples(examples, multiplier=multiplier)

    # Trim to target
    if len(augmented) > target_count:
        augmented = augmented[:target_count]

    # Add system prompt to each example
    system_prompt = _get_system_prompt(tenant_id)
    formatted = []
    for ex in augmented:
        formatted.append({
            "system": system_prompt,
            "instruction": ex["instruction"],
            "input": ex.get("input", ""),
            "output": ex["output"],
            "topic": ex["topic"],
            "tenant_id": tenant_id,
        })

    # Split into train/eval (90/10)
    random.shuffle(formatted)
    split_idx = int(len(formatted) * 0.9)
    train_set = formatted[:split_idx]
    eval_set = formatted[split_idx:]

    # Save
    train_path = config.sft_dir / "train.json"
    eval_path = config.sft_dir / "eval.json"
    train_path.write_text(json.dumps(train_set, indent=2), encoding="utf-8")
    eval_path.write_text(json.dumps(eval_set, indent=2), encoding="utf-8")

    # Also save in chat format for TRL
    chat_train = [_to_chat_format(ex) for ex in train_set]
    chat_eval = [_to_chat_format(ex) for ex in eval_set]
    (config.sft_dir / "train_chat.json").write_text(
        json.dumps(chat_train, indent=2), encoding="utf-8"
    )
    (config.sft_dir / "eval_chat.json").write_text(
        json.dumps(chat_eval, indent=2), encoding="utf-8"
    )

    logger.info(
        f"[{tenant_id}] SFT dataset: {len(train_set)} train, "
        f"{len(eval_set)} eval examples"
    )
    return formatted


def _get_system_prompt(tenant_id: str) -> str:
    if tenant_id == "sis":
        return (
            "You are an expert Student Information System assistant for District 42. "
            "You help school administrators, teachers, and staff with questions about "
            "enrollment, attendance, grading, transcripts, student records, accommodations, "
            "disciplinary procedures, and FERPA compliance. Always provide accurate information "
            "based on district policies. Never disclose student PII. If you are unsure about "
            "something, say so rather than guessing."
        )
    elif tenant_id == "mfg":
        return (
            "You are an expert manufacturing quality and operations assistant. "
            "You help production operators, quality engineers, and maintenance personnel "
            "with questions about SOPs, quality control, defect classification, CAPA processes, "
            "machine maintenance, safety protocols, ISO documentation, and regulatory compliance. "
            "Always prioritize safety in your responses. Never suggest skipping safety procedures. "
            "If you are unsure, direct the user to consult the relevant SOP or supervisor."
        )
    return "You are a helpful assistant."


def _to_chat_format(example: Dict) -> Dict:
    """Convert to TRL SFTTrainer chat format."""
    messages = []
    if example.get("system"):
        messages.append({"role": "system", "content": example["system"]})

    user_msg = example["instruction"]
    if example.get("input"):
        user_msg += f"\n\nContext: {example['input']}"
    messages.append({"role": "user", "content": user_msg})
    messages.append({"role": "assistant", "content": example["output"]})

    return {"messages": messages, "topic": example.get("topic", ""), "tenant_id": example.get("tenant_id", "")}


def build_all_sft_datasets() -> Dict:
    results = {}
    for tenant_id in TENANTS:
        dataset = build_sft_dataset(tenant_id)
        results[tenant_id] = len(dataset)
    return results


if __name__ == "__main__":
    results = build_all_sft_datasets()
    print(f"SFT dataset sizes: {results}")
